<!DOCTYPE html>
<html lang="it">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Meta Pixel Check — Dashboard</title>
<link rel="stylesheet" href="/style.css">
</head>
<body>
<nav>
  <span>Meta Pixel Check</span>
  <div>
    <a href="/" class="active">Dashboard</a>
    <a href="/history">Cronologia</a>
    <span class="user"><%= user %></span>
  </div>
</nav>

<main>
  <div class="cards">
    <div class="card"><span class="num"><%= totalToday %></span>Scan oggi</div>
    <div class="card"><span class="num"><%= present %></span>Pixel trovati</div>
    <div class="card"><span class="num"><%= absent %></span>Non trovati</div>
    <div class="card"><span class="num"><%= totalSites %></span>Siti controllati</div>
  </div>

  <form action="/scan" method="post" class="scan-bar">
    <button type="submit">🔄 Avvia scansione</button>
    <span>Ultimo scan: <%= lastScan %></span>
  </form>

  <h2>Risultati ultimo scan</h2>
  <table>
    <tr><th>Sito</th><th>Pixel</th><th>Eventi</th><th>Note</th></tr>
    <% lastResults.forEach(function(r) { %>
    <tr class="<%= r.present ? 'ok' : 'ko' %>">
      <td><%= r.url?.replace(/^https?:\/\//, '').replace(/^www\./, '') %></td>
      <td><%= r.pixelId || (r.present ? '?' : '—') %></td>
      <td><%= (r.events || []).join(', ') || '—' %></td>
      <td><%= r.note || (r.present ? '' : 'Non installato') %></td>
    </tr>
    <% }); %>
  </table>

  <h2>Scan recenti</h2>
  <table>
    <tr><th>Data</th><th>Siti</th><th>✅ Trovati</th><th>❌ Non trovati</th></tr>
    <% logs.forEach(function(l) { %>
    <tr><td><%= l.time %></td><td><%= l.sites %></td><td><%= l.found %></td><td><%= l.notFound %></td></tr>
    <% }); %>
  </table>
</main>
</body>
</html>
